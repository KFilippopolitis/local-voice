{
  "name": "local-voice",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 127.0.0.1 --port 1420",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "bundle:prepare": "bash ./scripts/prepare-bundled-backend.sh",
    "package:linux": "bash ./scripts/build-package-linux.sh",
    "doctor": "bash ./scripts/doctor.sh",
    "setup:ubuntu": "bash ./scripts/bootstrap-ubuntu.sh",
    "smoke:ubuntu": "bash ./scripts/smoke-test-ubuntu-docker.sh",
    "backend:sync": "cd python-backend && uv sync --frozen",
    "model:download": "cd python-backend && uv run python -m offline_voice_worker.cli download-model --model-profile small --output-dir models"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-global-shortcut": "^2.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.8"
  }
}
