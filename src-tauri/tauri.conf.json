{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Local Voice",
  "version": "0.1.0",
  "identifier": "com.codex.local-voice",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Local Voice",
        "width": 156,
        "height": 58,
        "minWidth": 156,
        "minHeight": 58,
        "maxWidth": 360,
        "maxHeight": 560,
        "x": 14,
        "y": 14,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": false,
        "visible": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
